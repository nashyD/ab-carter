# Anthropic API key for the AB Carter Assistant demo.
# Use a DEDICATED TSD demo key — never a personal key.
# Locally: copy to .env.local and fill in. For deploy: set in Vercel project env.
ANTHROPIC_API_KEY=

# Demo access gate. Set BOTH in the deployed (Vercel) environment to lock the demo;
# leave both unset locally for open local development.
#   DEMO_PASSWORD     — the shared access code the /api/chat route requires.
#   NEXT_PUBLIC_GATED — set to 1 to show the access-code screen in the UI.
DEMO_PASSWORD=
NEXT_PUBLIC_GATED=

# Premium voice (ElevenLabs). When ELEVENLABS_API_KEY is set, the assistant speaks
# via ElevenLabs; otherwise it falls back to the browser's built-in voice.
#   ELEVENLABS_VOICE_ID — optional; defaults to a clear premade voice. Set to a voice
#                         id from your ElevenLabs library to change it.
#   ELEVENLABS_MODEL    — optional; defaults to eleven_turbo_v2_5 (fast, multilingual).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Per-language voices (native speaker per market); fall back to ELEVENLABS_VOICE_ID:
ELEVENLABS_VOICE_ID_ES=
ELEVENLABS_VOICE_ID_ZH=
ELEVENLABS_MODEL=
